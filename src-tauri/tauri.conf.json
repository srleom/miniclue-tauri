{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniClue",
  "version": "0.1.0",
  "identifier": "miniclue",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev:fe",
    "beforeBuildCommand": "bun run build:fe"
  },
  "app": {
    "windows": [
      {
        "title": "MiniClue",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "asset:", "https://asset.localhost"],
        "script-src": ["'self'", "'unsafe-inline'", "'wasm-unsafe-eval'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "asset:", "https://asset.localhost", "data:", "blob:"],
        "font-src": ["'self'", "data:"],
        "connect-src": [
          "'self'",
          "https://*",
          "tauri:"
        ]
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/documents/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/llama-server"],
    "resources": [
      "resources/pdfium/**/*",
      "resources/models/**/*"
    ],
    "linux": {
      "appimage": {
        "files": {
          "binaries/": "binaries/"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
